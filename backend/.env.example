PORT=5000
# Comma-separated if you use both localhost and 127.0.0.1 for the Next app
CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Primary AI — xAI Grok (reports, coach chat, writing evaluation, simulations)
XAI_API_KEY=
XAI_MODEL=grok-2-latest
XAI_TIMEOUT_MS=120000

# Optional fallback if Grok is unavailable
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# O*NET occupational intelligence (requires migration 010 + ETL import)
OCCUPATION_MATCHING_ENABLED=true
# ONET_ACTIVE_RELEASE_ID=uuid-from-onet_releases
# ONET_MATCH_LIMIT=12
# ONET_CATALOG_CACHE_TTL_MS=300000
