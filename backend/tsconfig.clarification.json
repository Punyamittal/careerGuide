{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/clarification/**/*.ts",
    "src/clarification/**/*.d.ts",
    "src/config/env.d.ts",
    "src/config/supabase.d.ts"
  ],
  "exclude": [
    "src/clarification/**/*.test.ts",
    "src/modules/negotiation-v2/**"
  ]
}
